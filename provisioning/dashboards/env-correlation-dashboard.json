      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cf1s1g3beeccge" },
          "editorMode": "code", "format": "time_series", "rawQuery": true,
          "rawSql": "SELECT time_bucket('10 minutes', ts) AS time, MAX(heading_true) AS \"Heading (°)\" FROM nav_data WHERE $__timeFilter(ts) AND heading_true IS NOT NULL AND ('${vessel_id:raw}' = '$__all' OR vessel_id = '${vessel_id:raw}') GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
