          {
            "matcher": { "id": "byName", "options": "motion_severity" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Motion Severity (degrees)" },
              { "id": "unit", "value": "degree" }
            ]
