              { "id": "custom.axisLabel", "value": "RTT (ms)" },
              { "id": "unit", "value": "ms" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "heave_m" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Heave (m)" },
              { "id": "unit", "value": "lengthm" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cf1s1g3beeccge"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT r.ts AS time, r.metric_value AS \"rtt_ms\", concat(r.src,' → ',r.dst,' [', coalesce(r.aux->>'traffic_dir','forward'), ']') AS metric, n.heave_m FROM ps_test_results r LEFT JOIN LATERAL (SELECT heave_m FROM nav_data n WHERE n.ts BETWEEN r.ts - INTERVAL '30 seconds' AND r.ts + INTERVAL '30 seconds' AND ('${vessel_id}' = '$__all' OR n.vessel_id = '${vessel_id}') ORDER BY ABS(EXTRACT(EPOCH FROM (n.ts - r.ts))) LIMIT 1) n ON true WHERE r.metric_name = 'mean_rtt_ms' AND $__timeFilter(r.ts) AND (COALESCE('${src}','')='' OR r.src='${src}') AND (COALESCE('${dst}','')='' OR r.dst='${dst}') ORDER BY r.ts",
          "refId": "A"
        }
      ]
    },
