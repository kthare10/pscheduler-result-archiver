      "pluginVersion": "12.2.1",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cf1s1g3beeccge"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT tb AS time, avg_loss_pct, path, motion_severity FROM (SELECT time_bucket('5 minutes', ts) AS tb, AVG(metric_value) AS avg_loss_pct, concat(src,' → ',dst,' [', coalesce(aux->>'traffic_dir','forward'), ']') AS path FROM ps_test_results WHERE metric_name = 'loss_pct' AND $__timeFilter(ts) AND (COALESCE('${src}','')='' OR src='${src}') AND (COALESCE('${dst}','')='' OR dst='${dst}') GROUP BY 1, 3) perf LEFT JOIN LATERAL (SELECT AVG(SQRT(roll_deg*roll_deg + pitch_deg*pitch_deg)) AS motion_severity FROM nav_data WHERE ts BETWEEN perf.tb AND perf.tb + INTERVAL '5 minutes' AND ('${vessel_id}' = '$__all' OR vessel_id = '${vessel_id}')) nav ON true ORDER BY 1",
          "refId": "A"
        }
      ]
